# =============================================================================
# VendorFlow — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# Add every variable to your Vercel project (Settings → Environment Variables)
# for production. NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Root domain — used to build tenant subdomains
# Local dev: localhost:3000
# Production: vendorflow.com (or your custom domain)
NEXT_PUBLIC_APP_DOMAIN="localhost:3000"
# Email that gets seeded as the platform super-admin
PLATFORM_SUPER_ADMIN_EMAIL="admin@yourdomain.com"
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Database — PostgreSQL via Supabase
# Supabase dashboard → Settings → Database → Connection string
# TWO separate connection strings are required:
#   DATABASE_URL     = Pooler / Transaction mode  (port 6543) — used at runtime
#   DIRECT_DATABASE_URL = Direct / Session mode   (port 5432) — used by migrations
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
DIRECT_DATABASE_URL="postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Auth — Auth.js v5 (NextAuth)
# Generate secret: openssl rand -base64 32
# AUTH_URL must exactly match your deployment URL
# -----------------------------------------------------------------------------
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Optional OAuth providers (uncomment and fill to enable)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# OpenAI — AI CV summarization + duplicate detection embeddings
# https://platform.openai.com/api-keys
# Recommended: set a monthly spend limit at platform.openai.com/account/limits
# Cost estimate: ~$0.02 per CV summary, ~$0.00002 per embedding
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-proj-..."
OPENAI_SUMMARY_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# -----------------------------------------------------------------------------
# Stripe — Subscription billing
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys:  https://dashboard.stripe.com/apikeys
# Webhook:    https://dashboard.stripe.com/webhooks → Add endpoint
#             URL: https://yourdomain.com/api/webhooks/stripe
# Events to select:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_succeeded
#   invoice.payment_failed
#   customer.subscription.trial_will_end
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create in Stripe dashboard (Products → Pricing)
STRIPE_STARTER_MONTHLY_PRICE_ID="price_..."
STRIPE_STARTER_ANNUAL_PRICE_ID="price_..."
STRIPE_GROWTH_MONTHLY_PRICE_ID="price_..."
STRIPE_GROWTH_ANNUAL_PRICE_ID="price_..."
STRIPE_SCALE_MONTHLY_PRICE_ID="price_..."
STRIPE_SCALE_ANNUAL_PRICE_ID="price_..."

# -----------------------------------------------------------------------------
# Resend — Transactional email
# https://resend.com/api-keys
# Verify your sending domain at resend.com/domains before going live
# Free tier: 3,000 emails/month
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_FROM_NAME="VendorFlow"

# -----------------------------------------------------------------------------
# Cloudflare R2 — File storage (S3-compatible, no egress fees)
# https://dash.cloudflare.com → R2 → Create bucket → Manage API tokens
# Bucket name: vendorflow-uploads (or your choice)
# Token permissions: Object Read & Write on your bucket
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="vendorflow-uploads"
# Public URL — enable public access on the bucket or add a custom domain
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev"

# -----------------------------------------------------------------------------
# Trigger.dev — Background jobs (AI summarization, duplicate detection)
# https://trigger.dev → Your project → API Keys
# Required for async CV processing. Without this, summaries run synchronously.
# -----------------------------------------------------------------------------
TRIGGER_API_KEY="tr_dev_..."
TRIGGER_API_URL="https://api.trigger.dev"
TRIGGER_PROJECT_REF="proj_..."

# -----------------------------------------------------------------------------
# PostHog — Product analytics (optional but recommended)
# https://posthog.com → Settings → Project API key
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# -----------------------------------------------------------------------------
# Sentry — Error tracking (optional but recommended for production)
# https://sentry.io → Settings → Projects → Client Keys (DSN)
# -----------------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# -----------------------------------------------------------------------------
# Axiom — Structured logging (optional)
# https://axiom.co → Datasets → API Tokens
# -----------------------------------------------------------------------------
AXIOM_DATASET="vendorflow-logs"
AXIOM_TOKEN="xaat-..."
